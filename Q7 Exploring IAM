# 1. SETUP: Create a bucket (Skip if you already have one from Exp 3)
# Replace [UNIQUE_ID] with your name or a random number
export BUCKET_NAME="my-iam-test-bucket-[UNIQUE_ID]"
gcloud storage buckets create gs://$BUCKET_NAME --location=us-central1

# 2. DEFINE THE TEST USER
# Replace with the email provided by your examiner or a second account
export USER_EMAIL="testuser@gmail.com"

# 3. APPLY IAM POLICY
# This binds the user to the 'Storage Object Viewer' role ONLY for this bucket
gcloud storage buckets add-iam-policy-binding gs://$BUCKET_NAME \
    --member="user:$USER_EMAIL" \
    --role="roles/storage.objectViewer"

# 4. VERIFICATION
# This command pulls the policy to prove the role is assigned
gcloud storage buckets get-iam-policy gs://$BUCKET_NAME \
    --filter="bindings.members:$USER_EMAIL"
