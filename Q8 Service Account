Permission denied error

----
Shell commands
# 1. Define Variables
export SA_NAME="compute-viewer-sa"
export VM_NAME="sa-demo-vm"
export ZONE="us-central1-a"
export PROJECT_ID=$(gcloud config get-value project)

# 2. Create the Service Account
gcloud iam service-accounts create $SA_NAME \
    --display-name="SA for Compute Viewer access"

# 3. Assign the Compute Viewer Role to the Service Account
gcloud projects add-iam-policy-binding $PROJECT_ID \
    --member="serviceAccount:$SA_NAME@$PROJECT_ID.iam.gserviceaccount.com" \
    --role="roles/compute.viewer"

# 4. Create the VM and attach the Service Account
# We use --scopes=cloud-platform so the SA permissions are not restricted by legacy scopes
gcloud compute instances create $VM_NAME \
    --zone=$ZONE \
    --machine-type=e2-micro \
    --service-account="$SA_NAME@$PROJECT_ID.iam.gserviceaccount.com" \
    --scopes=cloud-platform

# 5. Verification: SSH into the VM and test permissions
gcloud compute ssh $VM_NAME --zone=$ZONE --command="
    echo '--- Testing List Permissions (Should work) ---'
    gcloud compute instances list
    echo '--- Testing Delete Permissions (Should fail) ---'
    gcloud compute instances delete $VM_NAME --zone=$ZONE --quiet
"
